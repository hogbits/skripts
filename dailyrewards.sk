    clear {dailyrewards.config.commands::1::*}
    add "give %%player%% oak_log 16" to {dailyrewards.config.commands::1::*}
    add "give %%player%% cooked_beef 8" to {dailyrewards.config.commands::1::*}
    add "eco give %%player%% 200" to {dailyrewards.config.commands::1::*}

    # Day 2
