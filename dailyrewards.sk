# =========================================================
# VARIABLES (Persistent)
# {dailyrewards.progress::%player%}   -> current reward index completed
# {dailyrewards.lastclaim::%player%}  -> timestamp of last claim
# =========================================================

# =========================================================
# UTILITY FUNCTIONS
# =========================================================

function dr_reward_count() :: number:
    return {dailyrewards.config.total_rewards}

function dr_start_slot() :: number:
    return {dailyrewards.config.start_slot}

function dr_bonus_slot() :: number:
    set {_start} to dr_start_slot()
    set {_count} to dr_reward_count()
    return {_start} + {_count}

function dr_waited(p: player) :: timespan:
    if {dailyrewards.lastclaim::%{_p}%} is not set:
        return 999999 seconds
    set {_waited} to difference between {dailyrewards.lastclaim::%{_p}%} and now
    return {_waited}

function dr_can_claim(p: player) :: boolean:
    if {dailyrewards.lastclaim::%{_p}%} is not set:
        return true
    set {_cooldown} to {@dailyrewards-cooldown-seconds} seconds
    set {_waited} to dr_waited({_p})
    if {_waited} >= {_cooldown}:
        return true
    return false

function dr_time_left(p: player) :: timespan:
    set {_cooldown} to {@dailyrewards-cooldown-seconds} seconds
    set {_waited} to dr_waited({_p})
    set {_remaining} to {_cooldown} - {_waited}
    if {_remaining} < 0 seconds:
        return 0 seconds
    return {_remaining}

function dr_time_left_text(p: player) :: text:
    set {_remaining} to dr_time_left({_p})
    set {_totalSeconds} to floor({_remaining} / 1 second)
    if {_totalSeconds} < 0:
        set {_totalSeconds} to 0

    set {_hours} to floor({_totalSeconds} / 3600)
    set {_afterHours} to {_totalSeconds} - ({_hours} * 3600)
    set {_minutes} to floor({_afterHours} / 60)
    set {_seconds} to {_afterHours} - ({_minutes} * 60)

    return "%{_hours}% hours, %{_minutes}% minutes, %{_seconds}% seconds."

function dr_claim_reward(p: player, index: number):
    set {_playerName} to name of {_p}
    loop {dailyrewards.config.commands::%{_index}%::*}:
        set {_cmd} to loop-value
        replace all "%%player%%" in {_cmd} with {_playerName}
        set {_cmdLower} to lowercase {_cmd}
        if {_cmdLower} starts with "give ":
            set {_cmd} to "minecraft:%{_cmd}%"
        execute console command {_cmd}
    set {dailyrewards.progress::%{_p}%} to {_index}
    set {dailyrewards.lastclaim::%{_p}%} to now

function dr_claim_basic_reward(p: player):
    set {_size} to {dailyrewards.config.basic.size}
    if {_size} is not set:
        set {_size} to 1
    if {_size} < 1:
        set {_size} to 1
    set {_pick} to metadata value "dailyrewards.basic.pending" of {_p}
    if {_pick} is not set:
        set {_pick} to random integer between 1 and {_size}
    if {_pick} < 1:
        set {_pick} to 1
    if {_pick} > {_size}:
        set {_pick} to {_size}
    set {_playerName} to name of {_p}
    loop {dailyrewards.config.basic.commands::%{_pick}%::*}:
        set {_cmd} to loop-value
        replace all "%%player%%" in {_cmd} with {_playerName}
        set {_cmdLower} to lowercase {_cmd}
        if {_cmdLower} starts with "give ":
            set {_cmd} to "minecraft:%{_cmd}%"
        execute console command {_cmd}
    delete metadata value "dailyrewards.basic.pending" of {_p}
    set {dailyrewards.lastclaim::%{_p}%} to now

function dr_render_rewards_gui(p: player):

    # Top filler row (slots 0-8)
    # loop 9 times:
    #     set slot (loop-number - 1) of {_p}'s current inventory to gray stained glass pane named " "

    set {_progress} to {dailyrewards.progress::%{_p}%}
    if {_progress} is not set:
        set {_progress} to 0

    set {_rewardCount} to dr_reward_count()
    set {_startSlot} to dr_start_slot()
    set {_bonusSlot} to dr_bonus_slot()
    set {_next} to {_progress} + 1
    set {_claimReady} to dr_can_claim({_p})
    set {_cooldownText} to dr_time_left_text({_p})

    # Reward slots: start slot + (index - 1)
    loop {_rewardCount} times:
        set {_i} to loop-number
        set {_slot} to {_startSlot} + {_i} - 1
        set {_rewardName} to {dailyrewards.config.name::%{_i}%}
        if {_rewardName} is not set:
            set {_rewardName} to "Day %{_i}% Reward"

        if {_i} <= {_progress}:
            set {_item} to minecart named "&7%{_rewardName}% - Claimed"
            set {_lore::*} to {dailyrewards.config.lore::%{_i}%::*}
            add "" to {_lore::*}
            add "&aStatus: Claimed" to {_lore::*}
            set lore of {_item} to {_lore::*}
            set slot {_slot} of {_p}'s current inventory to {_item}

        else:
            if {_i} = {_next}:
                if {_claimReady} is true:
                    set {_item} to chest minecart named "&a%{_rewardName}% - Claim Now"
                    #enchant {_item} with unbreaking 1
                    force {_item} to glint
                    set {_lore::*} to {dailyrewards.config.lore::%{_i}%::*}
                    add "" to {_lore::*}
                    add "&eClick to claim this reward." to {_lore::*}
                    set lore of {_item} to {_lore::*}
                    set slot {_slot} of {_p}'s current inventory to {_item}
                else:
                    set {_item} to furnace minecart named "&8%{_rewardName}% - Locked"
                    set {_lore::*} to {dailyrewards.config.lore::%{_i}%::*}
                    add "" to {_lore::*}
                    add "&7You can claim your next reward in:" to {_lore::*}
                    add "&7%{_cooldownText}%" to {_lore::*}
                    set lore of {_item} to {_lore::*}
                    set slot {_slot} of {_p}'s current inventory to {_item}
            else:
                set {_item} to furnace minecart named "&8%{_rewardName}% - Locked"
                set {_lore::*} to {dailyrewards.config.lore::%{_i}%::*}
                add "" to {_lore::*}
                # add "&7You can claim your next reward in:" to {_lore::*}
                # add "&7%{_cooldownText}%" to {_lore::*}
                set lore of {_item} to {_lore::*}
                set slot {_slot} of {_p}'s current inventory to {_item}

    # Bonus slot behavior (immediately after the final configured reward)
    set {_bonusSize} to {dailyrewards.config.basic.size}
    if {_bonusSize} is not set:
        set {_bonusSize} to 1
    if {_bonusSize} < 1:
        set {_bonusSize} to 1
    set {_bonusPick} to metadata value "dailyrewards.basic.pending" of {_p}
    if {_bonusPick} is not set:
        set {_bonusPick} to random integer between 1 and {_bonusSize}
        set metadata value "dailyrewards.basic.pending" of {_p} to {_bonusPick}
    if {_bonusPick} < 1:
        set {_bonusPick} to 1
        set metadata value "dailyrewards.basic.pending" of {_p} to {_bonusPick}
    if {_bonusPick} > {_bonusSize}:
        set {_bonusPick} to {_bonusSize}
        set metadata value "dailyrewards.basic.pending" of {_p} to {_bonusPick}

    set {_bonusName} to {dailyrewards.config.basic.name::%{_bonusPick}%}
    if {_bonusName} is not set:
        set {_bonusName} to "Repeatable Daily Reward"
    set {_bonusBaseLore::*} to {dailyrewards.config.basic.lore::%{_bonusPick}%::*}
    if {_bonusBaseLore::*} is not set:
        set {_bonusBaseLore::*} to "&7Random post-completion reward."

    if {_progress} >= {_rewardCount}:
        if {_claimReady} is true:
            set {_bonusItem} to repeater named "&a%{_bonusName}% - Claim"
            force {_bonusItem} to glint
            set {_bonusLore::*} to {_bonusBaseLore::*}
            add "" to {_bonusLore::*}
            add "&eClick to claim a random daily reward." to {_bonusLore::*}
            set lore of {_bonusItem} to {_bonusLore::*}
            set slot {_bonusSlot} of {_p}'s current inventory to {_bonusItem}
        else:
            set {_bonusItem} to repeater named "&7Daily reward already claimed. - Locked"
            # set {_bonusLore::*} to {_bonusBaseLore::*}
            add "" to {_bonusLore::*}
            add "&7You can claim your next reward in:" to {_bonusLore::*}
            add "&7%{_cooldownText}%" to {_bonusLore::*}
            set lore of {_bonusItem} to {_bonusLore::*}
            set slot {_bonusSlot} of {_p}'s current inventory to {_bonusItem}
    else:
        # set {_bonusItem} to repeater named "&8%{_bonusName}%"
        set {_bonusItem} to repeater named "&7Repatable Reward - Locked"
        # set {_bonusLore::*} to {_bonusBaseLore::*}
        add "" to {_bonusLore::*}
        add "&7Available after all %{_rewardCount}% rewards claimed." to {_bonusLore::*}
        set lore of {_bonusItem} to {_bonusLore::*}
        set slot {_bonusSlot} of {_p}'s current inventory to {_bonusItem}

    # Close button (slot 49)
    set slot 49 of {_p}'s current inventory to barrier named "&cClose"

function dr_open_rewards_gui(p: player):
    open chest inventory with 6 rows named "{@dailyrewards-menu-title}" to {_p}
    dr_render_rewards_gui({_p})

# =========================================================
# COMMANDS
# =========================================================

command /rewards [<text>] [<offline player>] [<number>]:
    trigger:
        if argument 1 is set:
            if argument 1 is "reset":
                if argument 2 is set:
                    set {_target} to argument 2
                else:
                    if player is not set:
                        send "&cUsage: /rewards reset <player>" to sender
                        stop
                    set {_target} to player

                delete {dailyrewards.progress::%{_target}%}
                delete {dailyrewards.lastclaim::%{_target}%}
                if {_target} is online:
                    delete metadata value "dailyrewards.basic.pending" of {_target}
                send "&aDaily rewards reset for %{_target}%." to sender
                if {_target} is online:
                    send "&eYour daily rewards progress has been reset." to {_target}
                stop
            else:
                if argument 1 is "set":
                    if argument 2 is not set:
                        send "&cUsage: /rewards set <player> <day>" to sender
                        stop
                    if argument 3 is not set:
                        send "&cUsage: /rewards set <player> <day>" to sender
                        stop

                    set {_target} to argument 2
                    set {_day} to argument 3
                    set {_maxDay} to dr_reward_count()

                    if {_day} < 1:
                        set {_day} to 1
                    if {_day} > {_maxDay}:
                        set {_day} to {_maxDay}

                    set {dailyrewards.progress::%{_target}%} to {_day} - 1
                    set {dailyrewards.lastclaim::%{_target}%} to now
                    if {_target} is online:
                        delete metadata value "dailyrewards.basic.pending" of {_target}

                    send "&aSet %{_target}%'s next claimable reward day to %{_day}%." to sender
                    if {_target} is online:
                        send "&eYour next claimable daily reward day was set to %{_day}%." to {_target}
                    stop
                else:
                    send "&cUsage: /rewards, /rewards reset <player>, /rewards set <player> <day>" to sender
                    stop

        if player is not set:
            send "&cOnly players can open the rewards GUI." to sender
            stop

        dr_open_rewards_gui(player)

# =========================================================
# GUI LOGIC
# =========================================================

on inventory click:
    if name of event-inventory is not "{@dailyrewards-menu-title}":
        stop

    cancel event

    if clicked inventory is not event-inventory:
        stop

    if event-slot is not set:
        stop

    set {_slot} to index of event-slot

    if {_slot} is 49:
        close player's inventory
        stop

    set {_startSlot} to dr_start_slot()
    set {_rewardCount} to dr_reward_count()
    set {_bonusSlot} to dr_bonus_slot()

    if {_slot} < {_startSlot}:
        stop
    if {_slot} > {_bonusSlot}:
        stop

    set {_progress} to {dailyrewards.progress::%player%}
    if {_progress} is not set:
        set {_progress} to 0

    # Post-completion basic reward claim (dynamic bonus slot)
    if {_progress} >= {_rewardCount}:
        if {_slot} is {_bonusSlot}:
            if dr_can_claim(player) is true:
                dr_claim_basic_reward(player)
                play sound "entity.player.levelup" with volume 1 and pitch 1.2 to player
                send "&aDaily reward claimed." to player
                dr_render_rewards_gui(player)
            else:
                send "&cYou can claim your next reward in: %dr_time_left_text(player)%" to player
        stop

    # Sequential reward claim handling
    set {_clickedIndex} to {_slot} - {_startSlot} + 1
    set {_nextIndex} to {_progress} + 1

    if {_clickedIndex} <= {_progress}:
        stop

    if {_clickedIndex} > {_rewardCount}:
        stop

    if {_clickedIndex} is not {_nextIndex}:
        stop

    if dr_can_claim(player) is false:
        send "&cYou can claim your next reward in: %dr_time_left_text(player)%" to player
        stop

    dr_claim_reward(player, {_clickedIndex})
    if {_clickedIndex} is {_rewardCount}:
        play sound "ui.toast.challenge_complete" with volume 1 and pitch 1 to player
    else:
        play sound "entity.player.levelup" with volume 1 and pitch 1.2 to player
    send "&aYou claimed Day %{_clickedIndex}% reward." to player
    dr_render_rewards_gui(player)

every 1 second:
    loop all players:
        if name of loop-player's current inventory is "{@dailyrewards-menu-title}":
            dr_render_rewards_gui(loop-player)

on inventory drag:
    if name of event-inventory is "{@dailyrewards-menu-title}":
        cancel event
