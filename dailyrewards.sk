# =========================================================
# Daily Rewards System (Skript 2.12.2, Paper 1.21.11)
# File: plugins/Skript/scripts/dailyrewards.sk
# =========================================================

# =========================================================
# Minecraft Color Codes
# &0 = Black        &1 = Dark Blue          &2 = Dark Green
# &3 = Dark Aqua    &4 = Dark Red           &5 = Dark Purple
# &6 = Gold         &7 = Gray               &8 = Dark Gray
# &9 = Blue         &a = Green              &b = Aqua
# &c = Red          &d = Light Purple       &e = Yellow
# &f = White
# =========================================================

# =========================================================
# REWARD CLAIM LOGIC
# - Sequential rewards must be claimed in order.
# - One claim per cooldown.
# - Cooldown starts at claim time.
# - Rewards do not expire.
# - After all daily rewards claimed, bonus slot grants random basic rewards.
# =========================================================

options:
    # Menu title
    dailyrewards-menu-title: &5Daily Rewards
    # Cooldown in seconds between rewards claim. Default is 86400 = 24 hours.
    dailyrewards-cooldown-seconds: 64800 #18 hour cooldown
    # First slot for Day 1 (0-48, because slot 49 is reserved for Close).
    dailyrewards-starting-slot: 9
    # Number of sequential rewards shown in this GUI.
    # Effective max depends on starting slot because bonus uses the next slot.
    dailyrewards-total-rewards: 31

# =========================================================
# CONFIGURATION
# - Edit values in this section to customize rewards.
# - Player progress variables are NOT cleared on reload.
# =========================================================

on script load:
    clear {dailyrewards.config::*}

    # Dynamic slot mapping:
    # - Reward 1 starts at configured starting slot
    # - Rewards fill sequentially
    # - Bonus slot is immediately after the last reward
    set {_configuredStart} to {@dailyrewards-starting-slot}
    if {_configuredStart} < 0:
        set {_configuredStart} to 0
    if {_configuredStart} > 48:
        set {_configuredStart} to 48
    set {dailyrewards.config.start_slot} to {_configuredStart}

    # Total sequential rewards shown in GUI.
    # Clamped to fit before slot 49 (close button), while leaving one slot for bonus.
    set {_maxRewards} to 48 - {_configuredStart}
    if {_maxRewards} < 1:
        set {_maxRewards} to 1

    set {_configuredTotal} to {@dailyrewards-total-rewards}
    if {_configuredTotal} < 1:
        set {_configuredTotal} to 1
    if {_configuredTotal} > {_maxRewards}:
        set {_configuredTotal} to {_maxRewards}
    set {dailyrewards.config.total_rewards} to {_configuredTotal}

    # -----------------------------
    # Sequential reward definitions
    # -----------------------------
    # Each reward supports:
    # - name            {dailyrewards.config.name::index::*}
    # - description     {dailyrewards.config.lore::index::*}
    # - commands        {dailyrewards.config.commands::index::*}

    loop {_configuredTotal} times:
        set {_i} to loop-number
        set {dailyrewards.config.name::%{_i}%} to "&eDay %{_i}% Reward"
        clear {dailyrewards.config.lore::%{_i}%::*}
        add "&7Daily login reward for Day %{_i}%." to {dailyrewards.config.lore::%{_i}%::*}
        clear {dailyrewards.config.commands::%{_i}%::*}
        add "give %%player%% bread 2" to {dailyrewards.config.commands::%{_i}%::*}

    # Example Reward 
    # set {dailyrewards.config.name::1} to "&eDay 1 Reward"
    # clear {dailyrewards.config.lore::1::*}
    # add "&7Starter food pack." to {dailyrewards.config.lore::1::*}
    # add "&eClaim this to continue progression." to {dailyrewards.config.lore::1::*}
    # clear {dailyrewards.config.commands::1::*}
    # add "give %%player%% bread 8" to {dailyrewards.config.commands::1::*}
    # add "give %%player%% apple 4" to {dailyrewards.config.commands::1::*}
    # add "excellentcrates key give %%player%% iron" to {dailyrewards.config.commands::1::*}

    set {dailyrewards.config.name::1} to "&eDay 01 Reward"
    clear {dailyrewards.config.lore::1::*}
    add "&716x Oak Logs" to {dailyrewards.config.lore::1::*}
    add "&78x Steaks" to {dailyrewards.config.lore::1::*}
